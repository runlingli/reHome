rules_version = '2';

// reHome Cloud Storage rules
// Layout:
//   /listings/{listingId}/{photoId}.jpg     listing photos (owner write, all auth read)
//   /users/{uid}/avatar.jpg                  avatar (owner write, public read)
//   /verification/{uid}/{file}               state ID upload — write only, never client read
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn()      { return request.auth != null; }
    function isOwner(uid)    { return signedIn() && request.auth.uid == uid; }
    function isImage()       { return request.resource.contentType.matches('image/.*'); }

    // Listing photos
    //
    // NOTE: cross-service rules (Storage → Firestore.get) require the Blaze
    // plan, which this project doesn't have. So we can't enforce
    // "eduVerified" or "is the listing's seller" directly here. The trust
    // model relies on the Firestore listings.create rule, which does require
    // eduVerified — meaning an attacker who tries to upload an orphan photo
    // can never associate it with a listing they don't own. Combined with
    // the size + image-type check below, this is acceptable for now.
    match /listings/{listingId}/{photo} {
      allow read:   if signedIn();
      allow create: if signedIn()
                    && request.resource.size < 8 * 1024 * 1024
                    && isImage();
      allow update, delete: if signedIn();
    }

    // Avatars (public read)
    match /users/{uid}/avatar {
      allow read:  if true;
      allow write: if isOwner(uid)
                    && request.resource.size < 2 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
    }

    // Local-ID verification uploads — write only (Cloud Function processes & deletes)
    match /verification/{uid}/{file} {
      allow read:   if false;
      allow write:  if isOwner(uid)
                    && request.resource.size < 8 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
